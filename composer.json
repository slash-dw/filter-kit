{
  "name": "slash-dw/filter-kit",
  "description": "SlashDw shared filter infrastructure for Laravel projects",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.5",
    "slash-dw/core-kit": "^0.0.2",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/support": "^13.0"
  },
  "require-dev": {
    "larastan/larastan": "^3.9",
    "laravel/pint": "^1.29",
    "orchestra/testbench": "^11.0",
    "phpunit/phpunit": "^12.0"
  },
  "scripts": {
    "lint": "@php vendor/bin/pint --test",
    "format": "@php vendor/bin/pint",
    "analyse": "@php vendor/bin/phpstan analyse -c phpstan.neon.dist --memory-limit=1G",
    "test": "@php vendor/bin/phpunit -c phpunit.xml.dist",
    "ci": [
      "@lint",
      "@analyse",
      "@test"
    ]
  },
  "autoload": {
    "psr-4": {
      "SlashDw\\FilterKit\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SlashDw\\FilterKit\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "SlashDw\\FilterKit\\FilterKitServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
